# ---------------------------------------------------------------------------
# ClickPipes operator configuration
#
# Copy real values in below. This file is read by main.py at startup
# (via python-dotenv). Values already exported in your shell take precedence
# over the ones set here.
# ---------------------------------------------------------------------------

# --- ClickHouse Cloud API (HTTP Basic auth key with the Admin role) ---------
# https://clickhouse.com/docs/cloud/manage/openapi
CH_ORG_ID=<YOUR_ORG_ID>
CH_KEY_ID=<YOUR_KEY_ID>
CH_KEY_SECRET=<YOUR_KEY_SECRET>
CH_SERVICE_ID=<EXISTING_CLICKHOUSE_CLOUD_SERVICE_ID>

# --- Postgres CDC source connection -----------------------------------------
PG_HOST=<POSTGRES_CDC_HOST>
PG_PORT=5432
PG_DATABASE=<POSTGRES_CDC_DATABASE>
PG_USERNAME=<POSTGRES_CDC_USERNAME>
PG_PASSWORD=<POSTGRES_CDC_PASSWORD>

# --- ClickPipe settings -----------------------------------------------------
CLICKPIPE_NAME=<NAME_FOR_YOUR_PIPE>
CLICKPIPE_DESTINATION_DATABASE=<CLICKHOUSE_DESTINATION_DATABASE>

# JSON array of table mappings to replicate.
CLICKPIPE_TABLE_MAPPINGS=[{"sourceSchemaName": "public", "sourceTable": "orders", "targetTable": "public_orders"}]

# Use an existing Postgres publication instead of having ClickPipes create one
# (avoids needing CREATE-on-database privileges). 
# LEAVE BLANK to let ClickPipes create the publication itself.
CLICKPIPE_PUBLICATION_NAME=<EXISTING_POSTGRES_PUBLICATION_NAME> 

# Initial-load tuning (baked in at creation time). Parallelism must be >= 4.
CLICKPIPE_INITIAL_LOAD_PARALLELISM=16
CLICKPIPE_INITIAL_LOAD_CPU_MILLICORES=24000
CLICKPIPE_INITIAL_LOAD_MEMORY_GB=96

# If true, block until the snapshot finishes then scale CDC compute back down.
CLICKPIPE_WAIT_AND_SCALE_DOWN=true
# Seconds to wait for the snapshot when the above is true ("none" = forever).
CLICKPIPE_WAIT_TIMEOUT_S=7200 # 2h for timeout
